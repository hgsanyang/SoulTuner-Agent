# ============================================================
# SoulTuner-Agent 环境变量模板
# 使用方法: cp .env.example .env && 编辑填入你的 API Key
# ============================================================

# === LLM API 密钥（至少填一个） ===
SILICONFLOW_API_KEY=sk-your-siliconflow-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# DASHSCOPE_API_KEY=sk-your-dashscope-key-here
# GOOGLE_API_KEY=your-google-key-here

# === 模型选择 ===
MODEL_NAME=deepseek-ai/DeepSeek-V3
EMBEDDING_MODEL_NAME=BAAI/bge-m3
GRAPHZEP_MODEL_NAME=deepseek-ai/DeepSeek-V3

# === 意图分析模型（可选：使用微调小模型加速） ===
# INTENT_LLM_PROVIDER=vllm
# INTENT_LLM_MODEL=qwen3.5-4b-soultuner

# === Neo4j 图数据库 ===
# Docker 环境下使用容器名；本地开发使用 localhost
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# === 本地模型推理（可选） ===
# 如果使用 vLLM 部署微调模型，填写地址
# VLLM_BASE_URL=http://localhost:8000/v1

# === 音乐数据目录（Docker 挂载用） ===
# 指向包含 processed_audio/ 和 mtg_sample/ 的目录
MUSIC_DATA_PATH=./data

# === 联网搜索（可选） ===
# TAVILY_API_KEY=tvly-your-key-here
# SEARXNG_BASE_URL=http://localhost:8888

# === 超时设置 ===
LLM_TIMEOUT=80
