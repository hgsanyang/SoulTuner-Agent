# ================================================================
# SoulTuner-Agent 环境变量配置模板
# 复制此文件为 .env，并填入你自己的值
# 不要把 .env 提交到 git！
# ================================================================

# ===== LLM API（三选一，推荐 SiliconFlow）=====
# 【推荐】SiliconFlow 硅基流动（DeepSeek / Qwen 等）
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_API_KEY=sk-your_siliconflow_key
MODEL_NAME=deepseek-ai/DeepSeek-V3
SILICONFLOW_API_KEY=sk-your_siliconflow_key

# 【可选】阿里云 DashScope（如用此项，注释掉上面三行并取消下面注释）
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_API_KEY=your_dashscope_key
# MODEL_NAME=qwen-plus

# ===== 其他 LLM 密钥（可选）=====
ZHIPU_API_KEY=your_zhipu_key
GOOGLE_API_KEY=your_google_key
TAVILY_API_KEY=your_tavily_key
# LANGSMITH_API_KEY=your_langsmith_key

# ===== Neo4j 图数据库 =====
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ===== 外部服务地址（默认本地启动，一般无需修改）=====
NETEASE_API_BASE=http://localhost:3000
SEARXNG_BASE_URL=http://localhost:8888
GRAPHZEP_BASE_URL=http://localhost:3100
PORT=3100

# ===== 路径配置（可选，一般无需修改）=====
# 如果你的音频文件在其他位置，设置此变量
# MUSIC_AUDIO_DATA_DIR=/your/path/to/audio
#
# NeteaseCloudMusicApi 的安装路径（startup_all.py 使用）
# NETEASE_API_DIR=/your/path/to/NeteaseCloudMusicApi

# ===== 模型镜像（国内用户可取消注释）=====
# HF_ENDPOINT=https://hf-mirror.com
