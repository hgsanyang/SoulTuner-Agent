# SoulTuner Agent environment template
# Copy this file to .env, then fill the required values.


# ------------------------------------------------------------------
# Required for the default DashScope setup
# If you switch MAIN_LLM_PROVIDER, fill that provider's key instead.
# ------------------------------------------------------------------

DASHSCOPE_API_KEY=你的_DashScope_Key
NEO4J_PASSWORD=你的_Neo4j_密码
MUSIC_DATA_PATH=../data


# ------------------------------------------------------------------
# Main model
# ------------------------------------------------------------------

MAIN_LLM_PROVIDER=dashscope
MODEL_NAME=qwen3.7-plus

INTENT_LLM_PROVIDER=dashscope
INTENT_LLM_MODEL=qwen3.7-plus
INTENT_LLM_FAST_MODEL=qwen-turbo
PLANNER_QUALITY_MODE=teacher

DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1


# ------------------------------------------------------------------
# Local services
# ------------------------------------------------------------------

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j

API_PORT=8501
NEXT_PUBLIC_API_URL=http://localhost:8501

SEARXNG_BASE_URL=http://localhost:8888
NETEASE_API_BASE=http://localhost:3000


# ------------------------------------------------------------------
# Recommendation defaults
# ------------------------------------------------------------------

MUSIC_WEB_SEARCH_ENABLED=true
NETEASE_SEARCH_LIMIT=10
WEB_MIX_IN_COUNT=4
WEB_FALLBACK_COUNT=10
CATALOG_GAP_MIN_LOCAL_RESULTS=8

EXPLANATION_MODE=tuner_async
DST_CLARIFICATION_CONFIDENCE_THRESHOLD=0.45

DENSE_TEXT_AUDIO_BACKEND=muq
MUSIC_DENSE_QUERY_VARIANTS=auto


# ------------------------------------------------------------------
# Knowledge search
# ------------------------------------------------------------------

MUSIC_KNOWLEDGE_GAP_ENABLED=true
MUSIC_KNOWLEDGE_STORE_PATH=../data/knowledge_cache/music_knowledge.sqlite
MUSIC_KNOWLEDGE_CACHE_PATH=../data/knowledge_cache/music_knowledge.jsonl
MUSIC_KNOWLEDGE_GAP_MIN_CONFIDENCE=0.55

MUSIC_KNOWLEDGE_VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_IMAGE=qdrant/qdrant:v1.15.5
MUSIC_KNOWLEDGE_QDRANT_COLLECTION=soultuner_music_knowledge
MUSIC_KNOWLEDGE_QDRANT_TIMEOUT_SECONDS=0.8

# If Docker Hub is slow in your network, use this image instead:
# QDRANT_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/qdrant/qdrant:v1.15.5


# ------------------------------------------------------------------
# Feedback and memory
# ------------------------------------------------------------------

MUSIC_FEEDBACK_DIR=
FEEDBACK_LOG_RAW_QUERY=0

# Optional episodic memory sidecars. Leave empty for the default Neo4j hot path.
# Valid examples: graphzep, mem0, graphzep,mem0
MEMORY_EPISODIC_BACKENDS=
MEMORY_MODE=structured
MEMORY_EVENT_DB=data/memory/memory_v2.sqlite3
MEMORY_CONSOLIDATION_ENABLED=true
MEMORY_CONSOLIDATION_MIN_EVENTS=5
MEMORY_CONSOLIDATION_COOLDOWN_SECONDS=900
MEMORY_CONSOLIDATION_MIN_CONFIDENCE=0.72
MEMORY_CONSOLIDATION_MIN_EVIDENCE=2
MEMORY_INFERRED_TTL_DAYS=45
MEMORY_RETRIEVAL_MIN_RELEVANCE=0.08
GRAPHZEP_BASE_URL=http://localhost:3100
GRAPHZEP_REQUEST_TIMEOUT_SECONDS=3.5
GRAPHZEP_TOTAL_TIMEOUT_SECONDS=4
GRAPHZEP_UNAVAILABLE_TTL_SECONDS=300
MEM0_CONFIG_PATH=


# ------------------------------------------------------------------
# Shared deployment safety
# ------------------------------------------------------------------

ADMIN_API_KEY=
API_KEY_REQUIRED=false
SHARED_SAFE_MODE=false


# ------------------------------------------------------------------
# Optional web-search providers
# ------------------------------------------------------------------

TAVILY_API_KEY=
ZHIPU_API_KEY=


# ------------------------------------------------------------------
# Optional local model providers
# ------------------------------------------------------------------

OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_API_KEY=
SiliconFlow_API_KEY=
GOOGLE_API_KEY=
VOLCENGINE_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

SGLANG_BASE_URL=http://localhost:8000/v1
# VLLM_BASE_URL=http://localhost:8000/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1


# ------------------------------------------------------------------
# Advanced runtime knobs
# ------------------------------------------------------------------

HYDE_LLM_PROVIDER=
HYDE_LLM_MODEL=

PLANNER_CACHE_TTL_SECONDS=300
PLANNER_CACHE_MAX_ENTRIES=256

EXPLANATION_FAST_MODE=false

RERANKER_ENABLED=false
RERANKER_DEVICE=cuda
RERANKER_TOP_K=10
RERANKER_BATCH_SIZE=16

HF_ENDPOINT=https://huggingface.co
HF_OFFLINE=false
HF_HUB_DISABLE_XET=1

MUSIC_M2D_TEXT_WARMUP=false
RECALL_SOURCE_TIMEOUT_SECONDS=60
TRI_ANCHOR_TEXT_TIMEOUT_SECONDS=8

TEACHER_LOG=1
TEACHER_LOG_DIR=data/teacher
TEACHER_LOG_STORE_TEXT=0

# ToolPlan v1 is observed by default; execution remains on the stable pipeline.
TOOL_PLAN_SHADOW_ENABLED=true
TOOL_PLAN_EXECUTION_ENABLED=false
TOOL_PLAN_TIMEOUT_SECONDS=20

LANGSMITH_API_KEY=
